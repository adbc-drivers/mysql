// part: metadata

[tags]
sql-type-name = "TINYINT UNSIGNED"

// part: query

SELECT CAST(255 AS UNSIGNED) AS res, CAST(0 AS UNSIGNED) AS res2, CAST(128 AS UNSIGNED) AS res3

// part: expected_schema

{
    "format": "+s",
    "children": [
        {
            "name": "res",
            "format": "L",
            "flags": ["nullable"]
        },
        {
            "name": "res2",
            "format": "L",
            "flags": ["nullable"]
        },
        {
            "name": "res3",
            "format": "L",
            "flags": ["nullable"]
        }
    ]
}

// part: expected

{"res": 255, "res2": 0, "res3": 128}
